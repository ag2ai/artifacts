{
  "name": "mcp-server-python",
  "type": "template",
  "display_name": "MCP Server (Python)",
  "description": "A production-ready Model Context Protocol server in Python with FastMCP, tool definitions, and tests",
  "version": "1.0.0",
  "authors": ["ag2ai"],
  "license": "Apache-2.0",
  "tags": ["mcp", "python", "server", "tools"],
  "template": {
    "scaffold": "scaffold/",
    "variables": {
      "project_name": {"prompt": "Project name", "default": "my-mcp-server", "transform": "slug"},
      "description": {"prompt": "Server description", "default": "A custom MCP server"}
    },
    "ignore": ["__pycache__", "*.pyc", ".git"],
    "post_install": ["uv sync"]
  },
  "skills": {"dir": "skills/", "auto_install": true},
  "depends": ["skills/ag2"]
}
