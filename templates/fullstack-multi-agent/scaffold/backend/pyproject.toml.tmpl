[project]
name = "{{ project_name }}-backend"
version = "0.1.0"
description = "{{ description }} — backend"
requires-python = ">=3.10"
dependencies = [
    "ag2>=0.11",
    "fastapi>=0.115",
    "uvicorn[standard]>=0.34",
    "pydantic>=2.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[dependency-groups]
dev = [
    "pytest>=8.0",
    "pytest-asyncio>=0.24",
    "httpx>=0.27",
]
